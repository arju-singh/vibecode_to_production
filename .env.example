# ----- Razorpay -----
# TEST keys start with rzp_test_ ; LIVE keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# From Razorpay Dashboard → Settings → Webhooks (you choose this secret)
RAZORPAY_WEBHOOK_SECRET=

# ----- App -----
PORT=3012
NODE_ENV=production
# Price in PAISE — the single source of truth. The browser is told this
# value only so it can render it; it can never choose what to pay.
# 5000 = ₹50 · 29900 = ₹299 · 49900 = ₹499
PRICE_PAISE=49900
# REQUIRED. Signs access tokens. Generate with: openssl rand -hex 32
TOKEN_SECRET=
# Comma-separated origin allowlist for cross-origin API use. Empty = same-origin only.
# e.g. ALLOWED_ORIGINS=https://arjusingh.com,https://www.arjusingh.com
ALLOWED_ORIGINS=
# ----- Firestore -----
# Payments live in Firestore (see lib/db.js). On Cloud Run the project and the
# service-account credentials are both ambient, so neither needs setting there.
# Locally you need BOTH of these:
#   1. gcloud auth application-default login
#   2. GOOGLE_CLOUD_PROJECT below
GOOGLE_CLOUD_PROJECT=vibe-roadmap-prod
# Collection holding payment records. Override only to isolate a test dataset
# from real payments — pointing this at a fresh name starts from zero buyers.
FIRESTORE_COLLECTION=payments

# ----- Admin Bypass -----
# Secret for admin content access bypass. Must be ≥32 chars. Leave empty to disable.
ADMIN_SECRET=

# ----- Direct UPI (optional, OFF by default) -----
# The zero-fee, zero-automation path — see Appendix A of the payments brief.
# Nothing tells the server a UPI payment happened, so YOU approve each one by
# hand against your bank statement:
#   GET  /api/admin/upi          → list claims  (Authorization: Bearer $ADMIN_SECRET)
#   POST /api/admin/upi/approve  → grant access {"ref":"upi_…"}
#   POST /api/admin/upi/reject   → decline      {"ref":"upi_…"}
# Leave UPI_VPA empty and this entire path stays disabled (endpoints 404).
# Requires ADMIN_SECRET to be set — without it nobody could approve anything.
UPI_VPA=
UPI_PAYEE_NAME=Vibe Coding Roadmap
