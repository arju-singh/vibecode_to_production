# /etc/nginx/sites-available/vibe-roadmap  (symlink into sites-enabled)
# Reverse proxy + TLS in front of the Node app on 127.0.0.1:3012.
#
# 1) Replace YOUR_DOMAIN below.
# 2) Get a cert:  sudo certbot --nginx -d YOUR_DOMAIN -d www.YOUR_DOMAIN
#    (certbot rewrites the :80 block to redirect to :443 automatically.)

server {
    listen 80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;
    # certbot will manage the redirect to https after you run it.
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # ssl_certificate / ssl_certificate_key lines are added by certbot.

    # Razorpay webhook posts a raw JSON body — don't let proxy buffering
    # or tiny limits break it.
    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:3012;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout 30s;
    }
}
